{
  "name": "lunch-buddy",
  "version": "1.21.10",
  "private": true,
  "scripts": {
    "build": "ng build",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "generate:env": "node tools/write-runtime-env.mjs",
    "prebuild": "npm run generate:env",
    "lint": "npm run lint:eslint && npm run lint:styles && npm run format:check",
    "lint:fix": "npm run lint:eslint:fix && npm run lint:styles:fix && npm run format",
    "lint:eslint:fix": "eslint . --max-warnings=0 --fix",
    "lint:eslint": "eslint . --max-warnings=0",
    "lint:styles:fix": "stylelint \"src/**/*.scss\" --fix",
    "lint:styles": "stylelint \"src/**/*.scss\"",
    "typecheck": "tsc --noEmit",
    "mcp": "node tools/diagnostics-mcp.mjs",
    "mcp:check": "node tools/mcp-smoke.mjs",
    "postinstall": "npm run generate:env && node tools/install-playwright.mjs",
    "prepare": "husky",
    "prestart": "npm run generate:env",
    "pretest": "npm run generate:env",
    "prewatch": "node tools/write-version.js && node tools/write-pwa-version.js",
    "release": "semantic-release",
    "start": "ng serve",
    "test:e2e": "playwright test",
    "test:integration": "ng run lunch-buddy:test-integration --watch=false",
    "test:watch": "ng test --watch",
    "test": "ng test --watch=false --coverage"
  },
  "prettier": {
    "tabWidth": 2,
    "useTabs": false,
    "singleQuote": true,
    "semi": true,
    "bracketSpacing": true,
    "arrowParens": "avoid",
    "trailingComma": "es5",
    "bracketSameLine": true,
    "printWidth": 80,
    "endOfLine": "lf",
    "overrides": [
      {
        "files": [
          "*.component.html",
          "*.directive.html"
        ],
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "lint-staged": {
    "*.{ts,js,html}": [
      "eslint --cache --fix --max-warnings=0 --no-warn-ignored",
      "prettier --write"
    ],
    "*.scss": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": "prettier --write"
  },
  "overrides": {
    "tar": "7.5.7",
    "npm": {
      "tar": "7.5.7"
    }
  },
  "dependencies": {
    "@angular/cdk": "^22.0.5",
    "@angular/common": "^22.0.7",
    "@angular/compiler": "^22.0.7",
    "@angular/core": "^22.0.7",
    "@angular/forms": "^22.0.7",
    "@angular/material": "^22.0.5",
    "@angular/platform-browser": "^22.0.7",
    "@angular/router": "^22.0.7",
    "@angular/service-worker": "^22.0.7",
    "@upstash/redis": "^1.38.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular-eslint/builder": "22.1.0",
    "@angular/build": "^22.0.7",
    "@angular/cli": "^22.0.7",
    "@angular/compiler-cli": "^22.0.7",
    "@axe-core/playwright": "^4.12.1",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@playwright/test": "^1.61.1",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/node": "^26.1.0",
    "@vercel/node": "^5.8.22",
    "@vitest/coverage-v8": "^4.1.10",
    "angular-eslint": "^22.1.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-rxjs-x": "^1.0.2",
    "eslint-plugin-sonarjs": "^4.1.0",
    "eslint-plugin-unicorn": "^70.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.1.0",
    "prettier": "^3.9.4",
    "semantic-release": "^25.0.8",
    "stylelint": "^17.14.0",
    "stylelint-config-prettier-scss": "^1.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-scss": "^7.2.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.1",
    "vercel": "^54.20.1",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
